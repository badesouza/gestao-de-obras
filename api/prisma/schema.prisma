generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EntityStatus {
  ACTIVE
  INACTIVE
}

enum OperatorStatus {
  ACTIVE
  INACTIVE
}

enum TenantUserStatus {
  ACTIVE
  INACTIVE
}

enum LicitacaoStatus {
  ACTIVE
  INACTIVE
}

enum CentroCustoStatus {
  ACTIVE
  INACTIVE
}

enum SolicitacaoServicoStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
  CONSOLIDATED
}

enum PedidoCompraStatus {
  DRAFT
  SENT
  PARTIAL
  RECEIVED
  CANCELLED
}

enum PropriedadeTipo {
  TEXTO
  DATA
  VALOR
  BOOLEAN
  ITEM_LICITACAO
  ITENS_LICITACAO
}

enum PropriedadeProductionRole {
  NONE
  INICIO
  CONCLUSAO
}

model Entity {
  id                      String       @id @default(uuid())
  name                    String
  status                  EntityStatus @default(ACTIVE)
  cnpj                    String?      @unique
  email                   String?
  phone                   String?
  legalRepresentativeName String?      @map("legal_representative_name")
  uf                      String?      @db.Char(2)
  municipalityId          Int?         @map("municipality_id")
  municipalityName        String?      @map("municipality_name")
  address                 String?
  coatOfArmsUrl           String?      @map("coat_of_arms_url")
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  auditLogs      PlatformAuditLog[]
  tenantUsers    TenantUser[]
  tenantAudits   TenantAuditLog[]
  licitacoes     Licitacao[]
  licitacaoItems LicitacaoItem[]
  centrosCusto   CentroCusto[]
  centroCustoPropriedades CentroCustoPropriedade[]
  registrosDiarios RegistroDiario[]
  centroCustoLicitacoes CentroCustoLicitacao[]
  centroCustoPropriedadeConfigs CentroCustoPropriedadeConfig[]
  registroDiarioValores RegistroDiarioValor[]
  registroDiarioValorItens RegistroDiarioValorItem[]
  cadastrosAuxiliares CadastroAuxiliar[]
  enderecosDescobertos EnderecoDescoberto[]
  registroMidias RegistroMidia[]
  equipes Equipe[]
  operadores Operador[]
  solicitacoesServico SolicitacaoServico[]
  solicitacaoServicoItens SolicitacaoServicoItem[]
  pedidosCompra PedidoCompra[]
  pedidoCompraItens PedidoCompraItem[]
  pedidoCompraItemOrigens PedidoCompraItemOrigem[]
  pedidoCompraRecebimentos PedidoCompraRecebimento[]
  fornecedores Fornecedor[]

  @@index([status])
  @@map("entities")
}

enum CadastroAuxiliarTipo {
  BAIRRO
  EQUIPE
  VEICULO
  EQUIPAMENTO
}

model CadastroAuxiliar {
  id        String               @id @default(uuid())
  entityId  String               @map("entity_id")
  tipo      CadastroAuxiliarTipo
  nome      String               @db.VarChar(150)
  ativo     Boolean              @default(true)
  ordem     Int                  @default(0)
  lat       Float?
  lng       Float?
  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @updatedAt @map("updated_at")

  entity Entity   @relation(fields: [entityId], references: [id])
  equipe Equipe?

  @@unique([entityId, tipo, nome])
  @@index([entityId, tipo, ativo])
  @@map("cadastros_auxiliares")
}

model PlatformOperator {
  id           String         @id @default(uuid())
  name         String
  email        String         @unique
  passwordHash String
  status       OperatorStatus @default(ACTIVE)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  auditLogs PlatformAuditLog[]

  @@map("platform_operators")
}

model PlatformAuditLog {
  id            String   @id @default(uuid())
  operatorId    String
  entityId      String?
  action        String
  resource      String
  previousValue Json?
  newValue      Json?
  metadata      Json?
  createdAt     DateTime @default(now())

  operator PlatformOperator @relation(fields: [operatorId], references: [id])
  entity   Entity?          @relation(fields: [entityId], references: [id])

  @@index([entityId])
  @@index([operatorId])
  @@index([createdAt])
  @@map("platform_audit_logs")
}

model TenantRole {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  permissions TenantRolePermission[]
  users       TenantUser[]

  @@map("tenant_roles")
}

model TenantPermission {
  id          String @id @default(uuid())
  code        String @unique
  description String
  module      String

  roles TenantRolePermission[]

  @@map("tenant_permissions")
}

model TenantRolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       TenantRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission TenantPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("tenant_role_permissions")
}

model TenantUser {
  id              String           @id @default(uuid())
  entityId        String           @map("entity_id")
  roleId          String           @map("role_id")
  name            String
  email           String
  passwordHash    String           @map("password_hash")
  status          TenantUserStatus @default(ACTIVE)
  isLiderEquipe   Boolean          @default(false) @map("is_lider_equipe")
  lastLoginAt     DateTime?        @map("last_login_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  entity               Entity          @relation(fields: [entityId], references: [id])
  role                 TenantRole      @relation(fields: [roleId], references: [id])
  auditLogs            TenantAuditLog[]
  licitacoesCreated    Licitacao[]     @relation("LicitacaoCreatedBy")
  licitacaoItemsCreated LicitacaoItem[] @relation("LicitacaoItemCreatedBy")
  centrosCustoCreated  CentroCusto[]   @relation("CentroCustoCreatedBy")
  propriedadesCreated  CentroCustoPropriedade[] @relation("PropriedadeCreatedBy")
  registrosDiariosCreated RegistroDiario[] @relation("RegistroDiarioCreatedBy")
  registrosDiariosUpdated RegistroDiario[] @relation("RegistroDiarioUpdatedBy")
  equipesLideradas Equipe[]
  solicitacoesServicoCreated SolicitacaoServico[] @relation("SolicitacaoServicoCreatedBy")
  pedidosCompraCreated PedidoCompra[] @relation("PedidoCompraCreatedBy")
  pedidoCompraRecebimentosCreated PedidoCompraRecebimento[] @relation("PedidoCompraRecebimentoCreatedBy")

  @@unique([entityId, email])
  @@index([entityId])
  @@index([status])
  @@map("tenant_users")
}

model Equipe {
  id          String    @id @default(uuid())
  entityId    String    @map("entity_id")
  cadastroId  String    @unique @map("cadastro_id")
  liderUserId String?   @map("lider_user_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  entity     Entity           @relation(fields: [entityId], references: [id])
  cadastro   CadastroAuxiliar @relation(fields: [cadastroId], references: [id], onDelete: Cascade)
  lider      TenantUser?      @relation(fields: [liderUserId], references: [id])
  operadores Operador[]

  @@index([entityId])
  @@map("equipes")
}

model Operador {
  id        String   @id @default(uuid())
  entityId  String   @map("entity_id")
  equipeId  String   @map("equipe_id")
  nome      String   @db.VarChar(150)
  cargo     String   @db.VarChar(100)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  entity Entity  @relation(fields: [entityId], references: [id])
  equipe Equipe  @relation(fields: [equipeId], references: [id], onDelete: Cascade)

  @@index([equipeId, ativo])
  @@index([entityId])
  @@map("operadores")
}

model TenantAuditLog {
  id            String   @id @default(uuid())
  entityId      String   @map("entity_id")
  userId        String?  @map("user_id")
  action        String
  resource      String
  previousValue Json?    @map("previous_value")
  newValue      Json?    @map("new_value")
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  entity Entity      @relation(fields: [entityId], references: [id])
  user   TenantUser? @relation(fields: [userId], references: [id])

  @@index([entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("tenant_audit_logs")
}

model Fornecedor {
  id          String   @id @default(uuid())
  entityId    String   @map("entity_id")
  razaoSocial String   @map("razao_social") @db.VarChar(250)
  cnpj        String?  @db.VarChar(18)
  contato     String?  @db.VarChar(150)
  telefone    String?  @db.VarChar(30)
  email       String?  @db.VarChar(150)
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  entity     Entity      @relation(fields: [entityId], references: [id])
  licitacoes Licitacao[]

  @@index([entityId, ativo])
  @@map("fornecedores")
}

model Licitacao {
  id              String          @id @default(uuid())
  entityId        String          @map("entity_id")
  identificacao   String          @db.VarChar(100)
  objeto          String          @db.VarChar(500)
  fornecedorId    String?         @map("fornecedor_id")
  status          LicitacaoStatus @default(ACTIVE)
  createdByUserId String          @map("created_by_user_id")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  entity       Entity               @relation(fields: [entityId], references: [id])
  createdBy    TenantUser           @relation("LicitacaoCreatedBy", fields: [createdByUserId], references: [id])
  fornecedor   Fornecedor?          @relation(fields: [fornecedorId], references: [id])
  items        LicitacaoItem[]
  centrosCusto CentroCustoLicitacao[]
  solicitacoesServico SolicitacaoServico[]

  @@unique([entityId, identificacao])
  @@index([entityId, status])
  @@map("licitacoes")
}

model LicitacaoItem {
  id              String          @id @default(uuid())
  licitacaoId     String          @map("licitacao_id")
  entityId        String          @map("entity_id")
  categoria       String?         @db.VarChar(100)
  descricao       String          @db.VarChar(500)
  unidadeMedida   String          @map("unidade_medida") @db.VarChar(50)
  quantidade      Decimal?        @db.Decimal(15, 4)
  valorUnitario   Decimal?        @map("valor_unitario") @db.Decimal(15, 4)
  status          LicitacaoStatus @default(ACTIVE)
  createdByUserId String          @map("created_by_user_id")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  licitacao Licitacao  @relation(fields: [licitacaoId], references: [id])
  entity    Entity     @relation(fields: [entityId], references: [id])
  createdBy TenantUser @relation("LicitacaoItemCreatedBy", fields: [createdByUserId], references: [id])
  registroValores RegistroDiarioValorItem[]
  solicitacaoServicoItens SolicitacaoServicoItem[]
  pedidoCompraItens PedidoCompraItem[]

  @@index([licitacaoId, status])
  @@index([entityId, licitacaoId])
  @@map("licitacao_items")
}

model CentroCusto {
  id                  String            @id @default(uuid())
  entityId            String            @map("entity_id")
  nome                String            @db.VarChar(200)
  dataPrevistaInicio  DateTime?         @map("data_prevista_inicio") @db.Date
  dataPrevistaFim     DateTime?         @map("data_prevista_fim") @db.Date
  dataRealizadaInicio DateTime?         @map("data_realizada_inicio") @db.Date
  dataRealizadaFim    DateTime?         @map("data_realizada_fim") @db.Date
  status              CentroCustoStatus @default(ACTIVE)
  createdByUserId     String            @map("created_by_user_id")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  entity             Entity                         @relation(fields: [entityId], references: [id])
  createdBy          TenantUser                     @relation("CentroCustoCreatedBy", fields: [createdByUserId], references: [id])
  licitacoes         CentroCustoLicitacao[]
  propriedadeConfigs CentroCustoPropriedadeConfig[]
  registrosDiarios   RegistroDiario[]

  @@unique([entityId, nome])
  @@index([entityId, status])
  @@map("centros_custo")
}

model CentroCustoLicitacao {
  centroCustoId String   @map("centro_custo_id")
  licitacaoId   String   @map("licitacao_id")
  entityId      String   @map("entity_id")
  createdAt     DateTime @default(now()) @map("created_at")

  centroCusto CentroCusto @relation(fields: [centroCustoId], references: [id], onDelete: Cascade)
  licitacao   Licitacao   @relation(fields: [licitacaoId], references: [id])
  entity      Entity      @relation(fields: [entityId], references: [id])

  @@id([centroCustoId, licitacaoId])
  @@map("centro_custo_licitacoes")
}

model CentroCustoPropriedade {
  id              String            @id @default(uuid())
  entityId        String            @map("entity_id")
  nome            String            @db.VarChar(100)
  tipo            PropriedadeTipo
  status          CentroCustoStatus @default(ACTIVE)
  createdByUserId String            @map("created_by_user_id")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  entity  Entity                         @relation(fields: [entityId], references: [id])
  createdBy TenantUser                   @relation("PropriedadeCreatedBy", fields: [createdByUserId], references: [id])
  configs CentroCustoPropriedadeConfig[]
  valores RegistroDiarioValor[]

  @@unique([entityId, nome])
  @@index([entityId, status])
  @@map("centro_custo_propriedades")
}

model CentroCustoPropriedadeConfig {
  id              String                    @id @default(uuid())
  centroCustoId   String                    @map("centro_custo_id")
  propriedadeId   String                    @map("propriedade_id")
  entityId        String                    @map("entity_id")
  columnOrder     Int                       @map("column_order")
  productionRole  PropriedadeProductionRole @default(NONE) @map("production_role")
  active          Boolean                   @default(true)
  createdAt       DateTime                  @default(now()) @map("created_at")
  updatedAt       DateTime                  @updatedAt @map("updated_at")

  centroCusto CentroCusto            @relation(fields: [centroCustoId], references: [id], onDelete: Cascade)
  propriedade CentroCustoPropriedade @relation(fields: [propriedadeId], references: [id])
  entity      Entity                 @relation(fields: [entityId], references: [id])

  @@unique([centroCustoId, propriedadeId])
  @@index([centroCustoId, active, columnOrder])
  @@map("centro_custo_propriedade_configs")
}

model RegistroDiario {
  id                    String   @id @default(uuid())
  centroCustoId         String   @map("centro_custo_id")
  entityId              String   @map("entity_id")
  data                  DateTime @db.Date
  lat                   Float?
  lng                   Float?
  enderecoGeocodificado String?  @map("endereco_geocodificado")
  createdByUserId       String   @map("created_by_user_id")
  updatedByUserId       String?  @map("updated_by_user_id")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  centroCusto CentroCusto           @relation(fields: [centroCustoId], references: [id], onDelete: Cascade)
  entity      Entity                @relation(fields: [entityId], references: [id])
  createdBy   TenantUser            @relation("RegistroDiarioCreatedBy", fields: [createdByUserId], references: [id])
  updatedBy   TenantUser?           @relation("RegistroDiarioUpdatedBy", fields: [updatedByUserId], references: [id])
  valores     RegistroDiarioValor[]
  midias      RegistroMidia[]

  @@index([centroCustoId, data])
  @@index([entityId, centroCustoId, data])
  @@index([entityId, lat, lng])
  @@map("registros_diarios")
}

model RegistroMidia {
  id               String   @id @default(uuid())
  registroDiarioId String   @map("registro_diario_id")
  entityId         String   @map("entity_id")
  tipo             String   @db.VarChar(10)
  nomeArquivo      String   @map("nome_arquivo") @db.VarChar(255)
  mimeType         String   @map("mime_type") @db.VarChar(100)
  tamanhoBytes     Int      @map("tamanho_bytes")
  dados            Bytes
  createdAt        DateTime @default(now()) @map("created_at")

  registroDiario RegistroDiario @relation(fields: [registroDiarioId], references: [id], onDelete: Cascade)
  entity         Entity         @relation(fields: [entityId], references: [id])

  @@index([registroDiarioId])
  @@map("registro_midias")
}

model RegistroDiarioValor {
  id               String   @id @default(uuid())
  registroDiarioId String   @map("registro_diario_id")
  propriedadeId    String   @map("propriedade_id")
  entityId         String   @map("entity_id")
  valorTexto       String?  @map("valor_texto") @db.VarChar(2000)
  valorData        DateTime? @map("valor_data") @db.Date
  valorDecimal     Decimal? @map("valor_decimal") @db.Decimal(15, 4)
  valorBoolean     Boolean? @map("valor_boolean")

  registroDiario RegistroDiario            @relation(fields: [registroDiarioId], references: [id], onDelete: Cascade)
  propriedade  CentroCustoPropriedade      @relation(fields: [propriedadeId], references: [id])
  entity       Entity                      @relation(fields: [entityId], references: [id])
  itens        RegistroDiarioValorItem[]

  @@unique([registroDiarioId, propriedadeId])
  @@map("registro_diario_valores")
}

model EnderecoDescoberto {
  id          String   @id @default(uuid())
  entityId    String   @map("entity_id")
  bairro      String   @db.VarChar(150)
  logradouro  String   @db.VarChar(300)
  lat         Float
  lng         Float
  createdAt   DateTime @default(now()) @map("created_at")

  entity Entity @relation(fields: [entityId], references: [id])

  @@unique([entityId, bairro, logradouro])
  @@index([entityId, bairro])
  @@map("enderecos_descobertos")
}

model RegistroDiarioValorItem {
  registroDiarioValorId String @map("registro_diario_valor_id")
  licitacaoItemId       String @map("licitacao_item_id")
  entityId              String @map("entity_id")

  registroDiarioValor RegistroDiarioValor @relation(fields: [registroDiarioValorId], references: [id], onDelete: Cascade)
  licitacaoItem       LicitacaoItem       @relation(fields: [licitacaoItemId], references: [id])
  entity              Entity              @relation(fields: [entityId], references: [id])

  @@id([registroDiarioValorId, licitacaoItemId])
  @@map("registro_diario_valor_itens")
}

model SolicitacaoServico {
  id              String                    @id @default(uuid())
  entityId        String                    @map("entity_id")
  numero          String                    @db.VarChar(30)
  servicoSlug     String                    @map("servico_slug") @db.VarChar(80)
  servicoNome     String                    @map("servico_nome") @db.VarChar(160)
  licitacaoId     String                    @map("licitacao_id")
  status          SolicitacaoServicoStatus  @default(DRAFT)
  prioridade      String                    @default("Media") @db.VarChar(20)
  justificativa   String                    @db.VarChar(2000)
  observacoes     String?                   @db.VarChar(2000)
  createdByUserId String                    @map("created_by_user_id")
  submittedAt     DateTime?                 @map("submitted_at")
  approvedAt      DateTime?                 @map("approved_at")
  createdAt       DateTime                  @default(now()) @map("created_at")
  updatedAt       DateTime                  @updatedAt @map("updated_at")

  entity    Entity                   @relation(fields: [entityId], references: [id])
  licitacao Licitacao                 @relation(fields: [licitacaoId], references: [id])
  createdBy TenantUser                @relation("SolicitacaoServicoCreatedBy", fields: [createdByUserId], references: [id])
  itens     SolicitacaoServicoItem[]
  origens   PedidoCompraItemOrigem[]

  @@unique([entityId, numero])
  @@index([entityId, servicoSlug, status])
  @@index([entityId, licitacaoId])
  @@map("solicitacoes_servico")
}

model SolicitacaoServicoItem {
  id                      String   @id @default(uuid())
  entityId                String   @map("entity_id")
  solicitacaoServicoId    String   @map("solicitacao_servico_id")
  licitacaoItemId         String   @map("licitacao_item_id")
  descricaoSnapshot       String   @map("descricao_snapshot") @db.VarChar(500)
  unidadeMedidaSnapshot   String   @map("unidade_medida_snapshot") @db.VarChar(50)
  valorUnitarioSnapshot   Decimal  @map("valor_unitario_snapshot") @db.Decimal(15, 4)
  quantidade              Decimal  @db.Decimal(15, 4)
  valorTotal              Decimal  @map("valor_total") @db.Decimal(15, 4)
  observacoes             String?  @db.VarChar(1000)
  createdAt               DateTime @default(now()) @map("created_at")

  entity             Entity              @relation(fields: [entityId], references: [id])
  solicitacaoServico SolicitacaoServico  @relation(fields: [solicitacaoServicoId], references: [id], onDelete: Cascade)
  licitacaoItem      LicitacaoItem       @relation(fields: [licitacaoItemId], references: [id])
  origens            PedidoCompraItemOrigem[]

  @@index([solicitacaoServicoId])
  @@index([entityId, licitacaoItemId])
  @@map("solicitacao_servico_itens")
}

model PedidoCompra {
  id              String             @id @default(uuid())
  entityId        String             @map("entity_id")
  numero          String             @db.VarChar(30)
  status          PedidoCompraStatus @default(DRAFT)
  observacoes     String?            @db.VarChar(2000)
  createdByUserId String             @map("created_by_user_id")
  sentAt          DateTime?          @map("sent_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  entity    Entity                   @relation(fields: [entityId], references: [id])
  createdBy TenantUser               @relation("PedidoCompraCreatedBy", fields: [createdByUserId], references: [id])
  itens     PedidoCompraItem[]

  @@unique([entityId, numero])
  @@index([entityId, status])
  @@map("pedidos_compra")
}

model PedidoCompraItem {
  id                      String   @id @default(uuid())
  entityId                String   @map("entity_id")
  pedidoCompraId          String   @map("pedido_compra_id")
  licitacaoItemId         String   @map("licitacao_item_id")
  descricaoSnapshot       String   @map("descricao_snapshot") @db.VarChar(500)
  unidadeMedidaSnapshot   String   @map("unidade_medida_snapshot") @db.VarChar(50)
  valorUnitarioSnapshot   Decimal  @map("valor_unitario_snapshot") @db.Decimal(15, 4)
  quantidadeTotal         Decimal  @map("quantidade_total") @db.Decimal(15, 4)
  valorTotal              Decimal  @map("valor_total") @db.Decimal(15, 4)
  createdAt               DateTime @default(now()) @map("created_at")

  entity        Entity                   @relation(fields: [entityId], references: [id])
  pedidoCompra  PedidoCompra             @relation(fields: [pedidoCompraId], references: [id], onDelete: Cascade)
  licitacaoItem LicitacaoItem            @relation(fields: [licitacaoItemId], references: [id])
  origens       PedidoCompraItemOrigem[]
  recebimentos  PedidoCompraRecebimento[]

  @@unique([pedidoCompraId, licitacaoItemId])
  @@index([entityId, licitacaoItemId])
  @@map("pedido_compra_itens")
}

model PedidoCompraItemOrigem {
  id                        String   @id @default(uuid())
  entityId                  String   @map("entity_id")
  pedidoCompraItemId        String   @map("pedido_compra_item_id")
  solicitacaoServicoId      String   @map("solicitacao_servico_id")
  solicitacaoServicoItemId  String   @map("solicitacao_servico_item_id")
  servicoSlug               String   @map("servico_slug") @db.VarChar(80)
  servicoNome               String   @map("servico_nome") @db.VarChar(160)
  quantidade                Decimal  @db.Decimal(15, 4)
  valorTotal                Decimal  @map("valor_total") @db.Decimal(15, 4)

  entity                 Entity                 @relation(fields: [entityId], references: [id])
  pedidoCompraItem       PedidoCompraItem       @relation(fields: [pedidoCompraItemId], references: [id], onDelete: Cascade)
  solicitacaoServico     SolicitacaoServico     @relation(fields: [solicitacaoServicoId], references: [id])
  solicitacaoServicoItem SolicitacaoServicoItem @relation(fields: [solicitacaoServicoItemId], references: [id])

  @@index([pedidoCompraItemId])
  @@index([solicitacaoServicoId])
  @@map("pedido_compra_item_origens")
}

model PedidoCompraRecebimento {
  id                 String   @id @default(uuid())
  entityId           String   @map("entity_id")
  pedidoCompraItemId String   @map("pedido_compra_item_id")
  quantidade         Decimal  @db.Decimal(15, 4)
  recebidoEm         DateTime @map("recebido_em") @db.Date
  responsavel        String   @db.VarChar(160)
  observacoes        String?  @db.VarChar(1000)
  createdByUserId    String   @map("created_by_user_id")
  createdAt          DateTime @default(now()) @map("created_at")

  entity           Entity           @relation(fields: [entityId], references: [id])
  pedidoCompraItem PedidoCompraItem @relation(fields: [pedidoCompraItemId], references: [id], onDelete: Cascade)
  createdBy        TenantUser       @relation("PedidoCompraRecebimentoCreatedBy", fields: [createdByUserId], references: [id])

  @@index([pedidoCompraItemId])
  @@index([entityId, recebidoEm])
  @@map("pedido_compra_recebimentos")
}
